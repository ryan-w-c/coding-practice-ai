{
  "id": "jump-game",
  "kind": "function",
  "entry": "canJump",
  "names": {
    "python": "can_jump"
  },
  "argTypes": [
    "any"
  ],
  "returnType": "any",
  "comparator": "exact",
  "cases": [
    {
      "name": "Example 1",
      "args": [
        [
          1,
          2,
          0,
          1,
          0
        ]
      ],
      "expected": true
    },
    {
      "name": "Example 2",
      "args": [
        [
          3,
          2,
          1,
          0,
          4
        ]
      ],
      "expected": false
    },
    {
      "name": "Edge Case: Single element",
      "args": [
        [
          0
        ]
      ],
      "expected": true
    },
    {
      "name": "Edge Case: Large jump at beginning",
      "args": [
        [
          10,
          1,
          1,
          1,
          1
        ]
      ],
      "expected": true
    },
    {
      "name": "Edge Case: Zero at the beginning",
      "args": [
        [
          0,
          1
        ]
      ],
      "expected": false
    },
    {
      "name": "Edge Case: High values",
      "args": [
        [
          100,
          0,
          0,
          0,
          0
        ]
      ],
      "expected": true
    }
  ]
}
