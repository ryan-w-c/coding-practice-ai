  },
  "argTypes": [
    "TreeNode"
  ],
  "returnType": "any",
  "comparator": "exact",
  "cases": [
    {
      "name": "should return [1, 3] for Example 1",
      "args": [
        [
          1,
          2,
          3
        ]
      ],
      "expected": [
        1,
        3
      ]
    },
    {
      "name": "should return [1, 3, 7] for Example 2",
      "args": [
        [
          1,
          2,
          3,
          4,
          5,
          6,
          7
        ]
      ],
      "expected": [
        1,
        3,
        7
      ]
    },
    {
      "name": "should return [] for an empty tree",
      "args": [
        null
      ],
      "expected": []
    },
    {
      "name": "should return [1] for a tree with only one node",
      "args": [
        [
          1
        ]
      ],
      "expected": [
        1
      ]
    },
    {
      "name": "should return [1, 3, 6] for a tree with mixed children",
      "args": [
        [
          1,
          2,
          3,
