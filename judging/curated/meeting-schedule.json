{
  "id": "meeting-schedule",
  "kind": "function",
  "entry": "canAttendAllMeetings",
  "names": {
    "python": "can_attend_all_meetings"
  },
  "argTypes": [
    "any"
  ],
  "returnType": "any",
  "comparator": "exact",
  "cases": [
    {
      "name": "should return false for intervals [(0,30),(5,10),(15,20)]",
      "args": [
        [
          [
            0,
            30
          ],
          [
            5,
            10
          ],
          [
            15,
            20
          ]
        ]
      ],
      "expected": false
    },
    {
      "name": "should return true for intervals [(5,8),(9,15)]",
      "args": [
        [
          [
            5,
            8
          ],
          [
            9,
            15
          ]
        ]
      ],
      "expected": true
    },
    {
      "name": "should return true for empty intervals",
      "args": [
        []
      ],
      "expected": true
    },
    {
      "name": "should return true for non-overlapping consecutive intervals [(0, 5), (5, 10), (10, 15)]",
      "args": [
        [
          [
            0,
            5
          ],
          [
            5,
            10
          ],
          [
            10,
            15
          ]
        ]
      ],
      "expected": true
    },
    {
      "name": "should return false for overlapping intervals [(1, 5), (2, 6)]",
      "args": [
        [
          [
            1,
            5
          ],
          [
            2,
            6
          ]
        ]
      ],
      "expected": false
    },
    {
      "name": "should return true for intervals that just touch [(1, 3), (3, 6), (6, 8)]",
      "args": [
        [
          [
            1,
            3
          ],
          [
            3,
            6
          ],
          [
            6,
            8
          ]
        ]
      ],
      "expected": true
    }
  ]
}
