{
  "id": "add-two-numbers",
  "kind": "function",
  "entry": "addTwoNumbers",
  "names": {
    "python": "add_two_numbers"
  },
  "argTypes": [
    "ListNode",
    "ListNode"
  ],
  "returnType": "ListNode",
  "comparator": "exact",
  "cases": [
    {
      "name": "should return [5, 7, 9] for l1 = [1, 2, 3] and l2 = [4, 5, 6]",
      "args": [
        [
          1,
          2,
          3
        ],
        [
          4,
          5,
          6
        ]
      ],
      "expected": [
        5,
        7,
        9
      ]
    },
    {
      "name": "should return [8, 1] for l1 = [9] and l2 = [9]",
      "args": [
        [
          9
        ],
        [
          9
        ]
      ],
      "expected": [
        8,
        1
      ]
    },
    {
      "name": "should handle carry over correctly",
      "args": [
        [
          2,
          4,
          3
        ],
        [
          5,
          6,
          4
        ]
      ],
      "expected": [
        7,
        0,
        8
      ]
    },
    {
      "name": "should return [0] for l1 = [0] and l2 = [0]",
      "args": [
        [
          0
        ],
        [
          0
        ]
      ],
      "expected": [
        0
      ]
    },
    {
      "name": "should handle different lengths of linked lists",
      "args": [
        [
          1,
          8
        ],
        [
          0
        ]
      ],
      "expected": [
        1,
        8
      ]
    }
  ]
}
