{
  "id": "merge-intervals",
  "kind": "function",
  "entry": "mergeIntervals",
  "names": {
    "python": "merge_intervals"
  },
  "argTypes": [
    "any"
  ],
  "returnType": "any",
  "comparator": "exact",
  "cases": [
    {
      "name": "should merge overlapping intervals correctly",
      "args": [
        [
          [
            1,
            3
          ],
          [
            1,
            5
          ],
          [
            6,
            7
          ]
        ]
      ],
      "expected": [
        [
          1,
          5
        ],
        [
          6,
          7
        ]
      ]
    },
    {
      "name": "should merge touching intervals",
      "args": [
        [
          [
            1,
            2
          ],
          [
            2,
            3
          ]
        ]
      ],
      "expected": [
        [
          1,
          3
        ]
      ]
    },
    {
      "name": "should handle no overlapping intervals",
      "args": [
        [
          [
            1,
            2
          ],
          [
            3,
            4
          ],
          [
            5,
            6
          ]
        ]
      ],
      "expected": [
        [
          1,
          2
        ],
        [
          3,
          4
        ],
        [
          5,
          6
        ]
      ]
    },
    {
      "name": "should handle all intervals overlapping into one",
      "args": [
        [
          [
            1,
            4
          ],
          [
            2,
            5
          ],
          [
            3,
            6
          ]
        ]
      ],
      "expected": [
        [
          1,
          6
        ]
      ]
    },
    {
      "name": "should handle a single interval",
      "args": [
        [
          [
            1,
            10
          ]
        ]
      ],
      "expected": [
        [
          1,
          10
        ]
      ]
    },
    {
      "name": "should handle non-overlapping intervals in non-sorted order",
      "args": [
        [
          [
            5,
            6
          ],
          [
            1,
            2
          ],
          [
            3,
            4
          ]
        ]
      ],
      "expected": [
        [
          1,
          2
        ],
        [
          3,
          4
        ],
        [
          5,
          6
        ]
      ]
    }
  ]
}
