          ],
          [
            10,
            11,
            12,
            13
          ],
          [
            14,
            20,
            30,
            40
          ]
        ],
        15
      ],
      "expected": false
    },
    {
      "name": "should return true for target at the beginning",
      "args": [
        [
          [
            1,
            2,
            4,
            8
          ],
          [
            10,
            11,
            12,
            13
          ],
          [
            14,
            20,
            30,
            40
          ]
        ],
        1
      ],
      "expected": true
    },
    {
      "name": "should return true for target at the end",
      "args": [
        [
          [
            1,
            2,
            4,
            8
          ],
          [
            10,
            11,
            12,
            13
          ],
          [
            14,
            20,
            30,
            40
          ]
        ],
        40
      ],
      "expected": true
