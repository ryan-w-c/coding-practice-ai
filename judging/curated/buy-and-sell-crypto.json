{
  "id": "buy-and-sell-crypto",
  "kind": "function",
  "entry": "maxProfit",
  "names": {
    "python": "max_profit"
  },
  "argTypes": [
    "any"
  ],
  "returnType": "any",
  "comparator": "exact",
  "cases": [
    {
      "name": "should return the maximum profit for a normal price list",
      "args": [
        [
          10,
          1,
          5,
          6,
          7,
          1
        ]
      ],
      "expected": 6
    },
    {
      "name": "should return 0 if no profitable transactions can be made",
      "args": [
        [
          10,
          8,
          7,
          5,
          2
        ]
      ],
      "expected": 0
    },
    {
      "name": "should return the maximum profit for increasing prices",
      "args": [
        [
          1,
          2,
          3,
          4,
          5
        ]
      ],
      "expected": 4
    },
    {
      "name": "should handle a single price",
      "args": [
        [
          5
        ]
      ],
      "expected": 0
    },
    {
      "name": "should handle two prices where profit is possible",
      "args": [
        [
          5,
          10
        ]
      ],
      "expected": 5
    },
    {
      "name": "should handle two prices where profit is not possible",
      "args": [
        [
          10,
          5
        ]
      ],
      "expected": 0
    }
  ]
}
