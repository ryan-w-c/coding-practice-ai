{
  "id": "depth-of-binary-tree",
  "kind": "function",
  "entry": "maxDepth",
  "names": {
    "python": "max_depth"
  },
  "argTypes": [
    "TreeNode"
  ],
  "returnType": "any",
  "comparator": "exact",
  "cases": [
    {
      "name": "should return correct depth for Example 1",
      "args": [
        [
          1,
          2,
          3,
          null,
          null,
          4
        ]
      ],
      "expected": 3
    },
    {
      "name": "should return 0 for an empty tree",
      "args": [
        null
      ],
      "expected": 0
    },
    {
      "name": "should return 1 for a single-node tree",
      "args": [
        [
          1
        ]
      ],
      "expected": 1
    },
    {
      "name": "should return correct depth for a left-heavy tree",
      "args": [
        [
          1,
          2,
          null,
          3
        ]
      ],
      "expected": 3
    },
    {
      "name": "should return correct depth for a right-heavy tree",
      "args": [
        [
          1,
          null,
          2,
          null,
          3
        ]
      ],
      "expected": 3
    },
    {
      "name": "should return correct depth for a balanced tree",
      "args": [
        [
          1,
          2,
          3,
          4,
          5,
          6,
          7
        ]
      ],
      "expected": 3
    }
  ]
}
