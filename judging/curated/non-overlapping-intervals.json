{
  "id": "non-overlapping-intervals",
  "kind": "function",
  "entry": "eraseOverlapIntervals",
  "names": {
    "python": "erase_overlap_intervals"
  },
  "argTypes": [
    "any"
  ],
  "returnType": "any",
  "comparator": "exact",
  "cases": [
    {
      "name": "should return 1 when removing overlapping interval",
      "args": [
        [
          [
            1,
            2
          ],
          [
            2,
            4
          ],
          [
            1,
            4
          ]
        ]
      ],
      "expected": 1
    },
    {
      "name": "should return 0 when intervals are non-overlapping",
      "args": [
        [
          [
            1,
            2
          ],
          [
            2,
            4
          ]
        ]
      ],
      "expected": 0
    },
    {
      "name": "should return 2 when multiple overlapping intervals exist",
      "args": [
        [
          [
            1,
            3
          ],
          [
            2,
            4
          ],
          [
            3,
            5
          ],
          [
            1,
            6
          ]
        ]
      ],
      "expected": 2
    },
    {
      "name": "should return 0 when there is only one interval",
      "args": [
        [
          [
            1,
            2
          ]
        ]
      ],
      "expected": 0
    },
    {
      "name": "should return 1 when the first interval overlaps with the second",
      "args": [
        [
          [
            1,
            5
          ],
          [
            2,
            3
          ],
          [
            4,
            6
          ]
        ]
      ],
      "expected": 1
    },
    {
      "name": "should handle negative values in intervals",
      "args": [
        [
          [
            -10,
            -5
          ],
          [
            -3,
            0
          ],
          [
            1,
            3
          ]
        ]
      ],
      "expected": 0
    }
  ]
}
