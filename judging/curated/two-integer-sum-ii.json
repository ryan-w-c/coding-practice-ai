{
  "id": "two-integer-sum-ii",
  "kind": "function",
  "entry": "twoSum",
  "names": {
    "python": "two_sum"
  },
  "argTypes": [
    "any",
    "any"
  ],
  "returnType": "any",
  "comparator": "exact",
  "cases": [
    {
      "name": "should return correct indices for the given example",
      "args": [
        [
          1,
          2,
          3,
          4
        ],
        3
      ],
      "expected": [
        1,
        2
      ]
    },
    {
      "name": "should handle negative numbers",
      "args": [
        [
          -3,
          -1,
          0,
          2,
          5
        ],
        1
      ],
      "expected": [
        2,
        4
      ]
    },
    {
      "name": "should handle larger arrays",
      "args": [
        [
          1,
          3,
          5,
          7,
          9,
          11
        ],
        16
      ],
      "expected": [
        3,
        6
      ]
    },
    {
      "name": "should handle an array of two elements",
      "args": [
        [
          2,
          7
        ],
        9
      ],
      "expected": [
        1,
        2
      ]
    },
    {
      "name": "should handle duplicate numbers with a unique solution",
      "args": [
        [
          1,
          1,
          3,
          5,
          7
        ],
        6
      ],
      "expected": [
        1,
        4
      ]
    }
  ]
}
