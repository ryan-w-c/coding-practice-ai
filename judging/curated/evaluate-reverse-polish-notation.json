{
  "id": "evaluate-reverse-polish-notation",
  "kind": "function",
  "entry": "evalRPN",
  "names": {
    "python": "eval_rpn"
  },
  "argTypes": [
    "any"
  ],
  "returnType": "any",
  "comparator": "exact",
  "cases": [
    {
      "name": "should return the correct value for a simple expression",
      "args": [
        [
          "1",
          "2",
          "+",
          "3",
          "*",
          "4",
          "-"
        ]
      ],
      "expected": 5
    },
    {
      "name": "should handle division with truncation toward zero",
      "args": [
        [
          "10",
          "3",
          "/"
        ]
      ],
      "expected": 3
    },
    {
      "name": "should handle negative numbers correctly",
      "args": [
        [
          "-2",
          "3",
          "*",
          "4",
          "+"
        ]
      ],
      "expected": -2
    },
    {
      "name": "should handle multiple operations",
      "args": [
        [
          "4",
          "13",
          "5",
          "/",
          "+"
        ]
      ],
      "expected": 6
    },
    {
      "name": "should return the correct value for a single number",
      "args": [
        [
          "42"
        ]
      ],
      "expected": 42
    },
    {
      "name": "should handle complex expressions",
      "args": [
        [
          "5",
          "1",
          "2",
          "+",
          "4",
          "*",
          "+",
          "3",
          "-"
        ]
      ],
      "expected": 14
    }
  ]
}
