        3
      ],
      "expected": [
        3,
        3,
        5,
        5,
        6,
        7
      ]
    },
    {
      "name": "single element",
      "args": [
        [
          1
        ],
        1
      ],
      "expected": [
        1
      ]
    },
    {
      "name": "k=1 identity",
      "args": [
        [
          9,
          8,
          7
        ],
        1
      ],
      "expected": [
        9,
        8,
        7
      ]
    },
    {
      "name": "k equals length",
      "args": [
        [
          1,
          2,
          3
        ],
        3
      ],
      "expected": [
        3
      ]
    },
    {
      "name": "two elements",
      "args": [
        [
          4,
          -2
        ],
        2
      ],
      "expected": [
        4
      ]
    },
    {
      "name": "max leaves window",
      "args": [
        [
          1,
          3,
          1,
          2,
