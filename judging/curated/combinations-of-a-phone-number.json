        "b",
        "c"
      ]
    },
    {
      "name": "digits 23",
      "args": [
        "23"
      ],
      "expected": [
        "ad",
        "ae",
        "af",
        "bd",
        "be",
        "bf",
        "cd",
        "ce",
        "cf"
