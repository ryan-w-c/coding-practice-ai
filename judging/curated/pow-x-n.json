{
  "id": "pow-x-n",
  "kind": "function",
  "entry": "myPow",
  "names": {
    "python": "my_pow"
  },
  "argTypes": [
    "float",
    "int"
  ],
  "returnType": "float",
  "comparator": "float",
  "cases": [
    {
      "name": "2^10",
      "args": [
        2,
        10
      ],
      "expected": 1024
    },
    {
      "name": "fractional base",
      "args": [
        2.1,
        3
      ],
      "expected": 9.261
    },
    {
      "name": "negative exponent",
      "args": [
        2,
        -2
      ],
      "expected": 0.25
    },
    {
      "name": "one to huge power (must be O(log n))",
      "args": [
        1,
        2147483647
      ],
      "expected": 1
    },
    {
      "name": "minus one to huge odd power",
      "args": [
        -1,
        2147483647
      ],
      "expected": -1
    },
    {
      "name": "int-min exponent underflows",
      "args": [
        2,
        -2147483648
      ],
      "expected": 0
    },
    {
      "name": "half to the fourth",
      "args": [
        0.5,
        4
      ],
      "expected": 0.0625
    },
    {
      "name": "negative base odd power",
      "args": [
        -2,
        3
      ],
      "expected": -8
    }
  ]
}
