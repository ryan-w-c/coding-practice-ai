{
  "id": "count-good-nodes-in-binary-tree",
  "kind": "function",
  "entry": "goodNodes",
  "names": {
    "python": "good_nodes"
  },
  "argTypes": [
    "TreeNode"
  ],
  "returnType": "any",
  "comparator": "exact",
  "cases": [
    {
      "name": "should return 3 for Example 1",
      "args": [
        [
          2,
          1,
          1,
          3,
          null,
          1,
          5
        ]
      ],
      "expected": 3
    },
    {
      "name": "should return 4 for Example 2",
      "args": [
        [
          1,
          2,
          -1,
          3,
          4
        ]
      ],
      "expected": 4
    },
    {
      "name": "should return 1 for a single node tree",
      "args": [
        [
          5
        ]
      ],
      "expected": 1
    },
    {
      "name": "should return 1 for a tree with decreasing values",
      "args": [
        [
          5,
          3,
          null,
          2,
          1
        ]
      ],
      "expected": 1
    },
    {
      "name": "should return 3 for a tree with all same values",
      "args": [
        [
          1,
          1,
          1
        ]
      ],
      "expected": 3
    }
  ]
}
